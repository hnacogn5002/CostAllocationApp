@model IEnumerable<Department>
@{
    ViewData["Title"] = "Danh Sách Phòng Ban";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-building me-2"></i>Phòng Ban</h1>
                <p>Quản lý danh sách phòng ban trong tổ chức</p>
            </div>
            <a asp-action="Create" class="btn btn-light fw-bold px-4" style="border-radius:10px;">
                <i class="fas fa-plus me-2"></i>Thêm Phòng Ban
            </a>
        </div>
    </div>
</div>

<div class="container pb-4">
    <!-- Search -->
    <div class="card mb-4">
        <div class="card-body py-2">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" id="tableSearch" class="form-control border-start-0" placeholder="Tìm kiếm phòng ban...">
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body empty-state">
                <div class="empty-icon">🏢</div>
                <h5>Chưa có phòng ban nào</h5>
                <p>Hãy thêm phòng ban đầu tiên để bắt đầu.</p>
                <a asp-action="Create" class="btn btn-primary-custom mt-2">
                    <i class="fas fa-plus me-2"></i>Thêm Ngay
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="table-modern bg-white">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:60px;">#</th>
                        <th><i class="fas fa-building me-2"></i>Tên Phòng Ban</th>
                        <th><i class="fas fa-align-left me-2"></i>Mô Tả</th>
                        <th style="width:120px;" class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var dept in Model)
                    {
                        <tr class="searchable-row">
                            <td><span class="badge" style="background:#e8eaf6;color:#1a237e;border-radius:8px;padding:0.4em 0.7em;">@(i++)</span></td>
                            <td>
                                <div class="fw-semibold" style="color:#1a237e;">@dept.Name</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(dept.Description))
                                {
                                    <span class="text-muted small">@dept.Description</span>
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">Không có mô tả</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn-action btn-edit" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@dept.Id" class="btn-action btn-view" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <form id="deleteForm-@dept.Id" asp-action="Delete" asp-route-id="@dept.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                    <button type="button" class="btn-action btn-delete" title="Xóa"
                                            onclick="confirmDelete('@Html.Raw(Html.Encode(dept.Name))', 'deleteForm-@dept.Id')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="mt-2 text-end text-muted small">Tổng: <strong>@Model.Count()</strong> phòng ban</div>
    }
</div>
