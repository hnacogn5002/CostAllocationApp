@model Department
@{
    ViewData["Title"] = "Sửa Phòng Ban";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-edit me-2"></i>Sửa Phòng Ban</h1>
        <p>Cập nhật thông tin phòng ban</p>
    </div>
</div>

<div class="container pb-4">
    <nav aria-label="breadcrumb" class="breadcrumb-custom">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i>Trang Chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Phòng Ban</a></li>
            <li class="breadcrumb-item active">Sửa: @Model.Name</li>
        </ol>
    </nav>

    <div class="card form-card">
        <div class="card-header" style="background:linear-gradient(135deg,#1565c0,#1976d2);color:white;">
            <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Cập Nhật Thông Tin</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label">
                        <i class="fas fa-building me-1 text-primary"></i>Tên Phòng Ban <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Name" class="form-control" maxlength="100" required />
                    <span asp-validation-for="Name" class="invalid-feedback d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label">
                        <i class="fas fa-align-left me-1 text-primary"></i>Mô Tả
                    </label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <hr />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4"><i class="fas fa-times me-1"></i>Hủy</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="fas fa-save me-2"></i>Cập Nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
