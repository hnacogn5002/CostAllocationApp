@model IEnumerable<CostAllocation>
@{
    ViewData["Title"] = "Phân Bổ Chi Phí";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-chart-pie me-2"></i>Phân Bổ Chi Phí</h1>
                <p>Kết quả tính toán và phân bổ chi phí chung cho từng phòng ban</p>
            </div>
            <a asp-action="Create" class="btn btn-light fw-bold px-4" style="border-radius:10px;">
                <i class="fas fa-plus me-2"></i>Tạo Phân Bổ
            </a>
        </div>
    </div>
</div>

<div class="container pb-4">
    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card stat-card-blue">
                <div class="stat-number" data-counter="@Model.Count()">0</div>
                <div class="stat-label"><i class="fas fa-list me-1"></i>Tổng Phân Bổ</div>
                <div class="stat-icon">📊</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-card-green">
                <div class="stat-label mb-1"><i class="fas fa-coins me-1"></i>Tổng Đã Phân Bổ</div>
                <div style="font-size:1.05rem;font-weight:700;">@Model.Sum(m=>m.AllocatedAmount).ToString("N0") ₫</div>
                <div class="stat-icon">💰</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-card-purple">
                <div class="stat-number">@Model.Select(m=>m.DepartmentId).Distinct().Count()</div>
                <div class="stat-label"><i class="fas fa-building me-1"></i>Phòng Ban Liên Quan</div>
                <div class="stat-icon">🏢</div>
            </div>
        </div>
    </div>

    <!-- Search -->
    <div class="card mb-4">
        <div class="card-body py-2">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" id="tableSearch" class="form-control border-start-0" placeholder="Tìm kiếm phân bổ...">
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body empty-state">
                <div class="empty-icon">📊</div>
                <h5>Chưa có phân bổ nào</h5>
                <p>Hãy tạo phân bổ chi phí đầu tiên.</p>
                <a asp-action="Create" class="btn btn-primary-custom mt-2"><i class="fas fa-plus me-2"></i>Tạo Ngay</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-modern bg-white">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:50px;">#</th>
                        <th><i class="fas fa-dollar-sign me-2"></i>Chi Phí Chung</th>
                        <th><i class="fas fa-building me-2"></i>Phòng Ban</th>
                        <th><i class="fas fa-percent me-2"></i>Tỷ Lệ</th>
                        <th><i class="fas fa-coins me-2"></i>Số Tiền Phân Bổ</th>
                        <th><i class="fas fa-calendar me-2"></i>Ngày Phân Bổ</th>
                        <th><i class="fas fa-sticky-note me-2"></i>Ghi Chú</th>
                        <th style="width:100px;" class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var alloc in Model.OrderByDescending(m => m.AllocatedDate))
                    {
                        <tr class="searchable-row">
                            <td><span class="badge" style="background:#e8eaf6;color:#1a237e;border-radius:8px;">@(i++)</span></td>
                            <td>
                                <div class="fw-semibold" style="color:#1a237e;">
                                    @(alloc.OverheadCost?.CostName ?? $"Chi phí #{alloc.OverheadCostId}")
                                </div>
                                <small class="text-muted">@(alloc.OverheadCost?.TotalAmount.ToString("N0")) ₫</small>
                            </td>
                            <td>
                                <span class="badge" style="background:#e8eaf6;color:#1a237e;border-radius:8px;padding:0.4em 0.75em;">
                                    🏢 @(alloc.Department?.Name ?? $"Phòng #{alloc.DepartmentId}")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:60px;background:#e8eaf6;border-radius:20px;height:6px;">
                                        <div style="width:@(alloc.AllocationRate)%;background:linear-gradient(135deg,#1a237e,#3949ab);border-radius:20px;height:6px;"></div>
                                    </div>
                                    <span class="fw-semibold" style="color:#1a237e;">@alloc.AllocationRate%</span>
                                </div>
                            </td>
                            <td><span class="amount-display">@alloc.AllocatedAmount.ToString("N0") ₫</span></td>
                            <td><span class="text-muted small">@alloc.AllocatedDate.ToString("dd/MM/yyyy")</span></td>
                            <td><span class="text-muted small">@(string.IsNullOrWhiteSpace(alloc.Note) ? "—" : alloc.Note)</span></td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@alloc.Id" class="btn-action btn-view" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                    <form id="deleteForm-@alloc.Id" asp-action="Delete" asp-route-id="@alloc.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                    <button type="button" class="btn-action btn-delete" title="Xóa"
                                            onclick="confirmDelete('Phân bổ #@alloc.Id', 'deleteForm-@alloc.Id')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
