@model CostAllocation
@{
    ViewData["Title"] = "Tạo Phân Bổ Chi Phí";
    var departments = ViewBag.Departments as IEnumerable<Department> ?? Enumerable.Empty<Department>();
    var overheadCosts = ViewBag.OverheadCosts as IEnumerable<OverheadCost> ?? Enumerable.Empty<OverheadCost>();
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-chart-pie me-2"></i>Tạo Phân Bổ Chi Phí</h1>
        <p>Phân bổ chi phí chung cho phòng ban theo tỷ lệ phần trăm</p>
    </div>
</div>

<div class="container pb-4">
    <nav aria-label="breadcrumb" class="breadcrumb-custom">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i>Trang Chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Phân Bổ</a></li>
            <li class="breadcrumb-item active">Tạo Mới</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header" style="background:linear-gradient(135deg,#4a148c,#7b1fa2);color:white;">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Thông Tin Phân Bổ</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate id="allocationForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="form-section-title">Chọn Chi Phí & Phòng Ban</div>

                        <div class="mb-4">
                            <label asp-for="OverheadCostId" class="form-label">
                                <i class="fas fa-dollar-sign me-1 text-purple"></i>Chi Phí Chung <span class="text-danger">*</span>
                            </label>
                            <select asp-for="OverheadCostId" class="form-select" id="OverheadCostId" required>
                                <option value="">-- Chọn chi phí chung --</option>
                                @foreach (var cost in overheadCosts)
                                {
                                    <option value="@cost.Id" data-amount="@cost.TotalAmount">
                                        @cost.CostName — @cost.TotalAmount.ToString("N0") ₫
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="OverheadCostId" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DepartmentId" class="form-label">
                                <i class="fas fa-building me-1 text-primary"></i>Phòng Ban <span class="text-danger">*</span>
                            </label>
                            <select asp-for="DepartmentId" class="form-select" required>
                                <option value="">-- Chọn phòng ban --</option>
                                @foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">🏢 @dept.Name</option>
                                }
                            </select>
                            <span asp-validation-for="DepartmentId" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="form-section-title">Tỷ Lệ Phân Bổ</div>

                        <div class="mb-4">
                            <label asp-for="AllocationRate" class="form-label">
                                <i class="fas fa-percent me-1 text-warning"></i>Tỷ Lệ Phần Trăm (%) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="AllocationRate" class="form-control" id="AllocationRate"
                                       type="number" min="0" max="100" step="0.01"
                                       placeholder="VD: 25.00" required />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="AllocationRate" class="invalid-feedback d-block"></span>
                            <div class="form-text">Nhập từ 0 đến 100. Hệ thống sẽ tự tính số tiền.</div>
                        </div>

                        <!-- Live Preview -->
                        <div class="preview-box d-none mb-4">
                            <div class="p-3 rounded-3" style="background:linear-gradient(135deg,#e8eaf6,#f3e5f5);border:2px solid #7b1fa2;">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="small fw-bold" style="color:#4a148c;"><i class="fas fa-calculator me-1"></i>Số Tiền Phân Bổ (Tự Động Tính)</div>
                                        <div id="allocatedAmountPreview" class="amount-display large" style="color:#4a148c;">—</div>
                                    </div>
                                    <div style="font-size:2rem;">🧮</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Note" class="form-label">
                                <i class="fas fa-sticky-note me-1 text-secondary"></i>Ghi Chú
                            </label>
                            <textarea asp-for="Note" class="form-control" rows="2"
                                      placeholder="Ghi chú thêm về khoản phân bổ này..."></textarea>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4"><i class="fas fa-times me-1"></i>Hủy</a>
                            <button type="submit" class="btn btn-primary-custom px-4">
                                <i class="fas fa-calculator me-2"></i>Tính Toán & Lưu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Help Card -->
        <div class="col-md-4">
            <div class="card" style="position:sticky;top:80px;">
                <div class="card-header" style="background:#f8f9ff;">
                    <h6 class="mb-0" style="color:#1a237e;"><i class="fas fa-lightbulb me-2"></i>Hướng Dẫn</h6>
                </div>
                <div class="card-body p-3">
                    <div class="small">
                        <div class="mb-3 p-2 rounded" style="background:#e8eaf6;">
                            <strong style="color:#1a237e;">🧮 Công Thức Tính</strong><br>
                            <code>Số tiền = Tổng chi phí × Tỷ lệ / 100</code>
                        </div>
                        <div class="mb-2"><strong>Ví dụ:</strong></div>
                        <ul class="ps-3 mb-3" style="color:#455a64;">
                            <li>Chi phí: 10.000.000 ₫</li>
                            <li>Tỷ lệ: 25%</li>
                            <li>Kết quả: <strong>2.500.000 ₫</strong></li>
                        </ul>
                        <div class="p-2 rounded" style="background:#fff3e0;">
                            <strong style="color:#e65100;">⚠️ Lưu ý:</strong>
                            <div style="color:#455a64;">Tổng tỷ lệ phân bổ cho một chi phí không nên vượt quá 100%.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Pass cost amounts to JS for live calculator
        window.costAmounts = {
            @foreach (var cost in overheadCosts)
            {
                @:@cost.Id: @cost.TotalAmount,
            }
        };
        // Show preview box when inputs change
        document.getElementById('AllocationRate').addEventListener('input', function() {
            document.querySelector('.preview-box')?.classList.remove('d-none');
        });
        document.getElementById('OverheadCostId').addEventListener('change', function() {
            document.querySelector('.preview-box')?.classList.remove('d-none');
        });
    </script>
}
